from pymilvus import connections, Collection, utility

# 1. Connect to your target Milvus instance
connections.connect("default", host="localhost", port="19530")

def load_and_verify(collection_name):
    # Check if collection exists
    if not utility.has_collection(collection_name):
        print(f"Collection '{collection_name}' not found.")
        return

    # 2. Initialize the collection object
    col = Collection(collection_name)

    # 3. Load the collection into memory (Crucial step!)
    print(f"Loading collection: {collection_name}...")
    col.load() 
    
    # Wait until loading is complete
    utility.wait_for_loading_complete(collection_name)
    print(f"Collection {collection_name} is now in memory.")

    # 4. Filter and Search
    # Replace 'vector_field' and 'id_field' with your actual schema names
    search_params = {"metric_type": "L2", "params": {"nprobe": 10}}
    
    # Example: Searching for a dummy vector with a scalar filter
    # Adjust the filter (expr) to match your data (e.g., "id > 0" or "category == 'A'")
    results = col.search(
        data=[[0.1] * 128],  # Example dummy vector (ensure dim matches schema)
        anns_field="embeddings", 
        param=search_params,
        limit=5,
        expr="id > 0",  # This is your boolean filter
        output_fields=["id", "metadata"] # Fields to return
    )

    for hits in results:
        for hit in hits:
            print(f"Hit: {hit.id}, Distance: {hit.distance}, Fields: {hit.entity.to_dict()}")

# List all collections and process them
collections = utility.list_collections()
for name in collections:
    load_and_verify(name)
